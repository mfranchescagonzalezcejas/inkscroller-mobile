# ===========================================================
# InkScroller Flutter — dart-define reference
# ===========================================================
# Flutter does NOT use .env files natively.
# This file documents the --dart-define variables used per flavor.
#
# HOW TO USE LOCALLY:
#   Pass these as --dart-define flags when running the app, or
#   use the .run/ configs in Android Studio (already committed).
#
# HOW TO USE IN CI:
#   Store values as GitHub Secrets and pass them to the build step.
#   See SECURITY_PUBLIC_READINESS.md §3 for full CI instructions.
#
# NEVER create a real .env file with secrets — .dart-defines/ is
# already excluded by .gitignore for local overrides.
# ===========================================================

# -- API Base URL (per flavor) --------------------------------
# The backend Cloud Run URL for each environment.
# These are passed via --dart-define=API_BASE_URL=<url>
# dev:     https://inkscroller-backend-<project-number-dev>.us-central1.run.app
# staging: https://inkscroller-backend-<project-number-staging>.us-central1.run.app
# pro:     https://inkscroller-backend-<project-number-pro>.us-central1.run.app
API_BASE_URL=https://your-cloud-run-url.run.app

# -- Firebase Config ------------------------------------------
# Public showcase repo note:
# `lib/firebase_options.dart` is intentionally sanitized and expects
# Firebase values via `--dart-define` / CI environment injection.
# Native Firebase files are still required locally for Android/iOS bootstrapping.
# See docs/firebase-config-example.md for file structure.
# See SECURITY_PUBLIC_READINESS.md for CI injection steps.

FIREBASE_ANDROID_DEV_API_KEY=REPLACE_ME
FIREBASE_ANDROID_DEV_APP_ID=REPLACE_ME
FIREBASE_ANDROID_DEV_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_ANDROID_DEV_PROJECT_ID=REPLACE_ME
FIREBASE_ANDROID_DEV_STORAGE_BUCKET=REPLACE_ME

FIREBASE_ANDROID_STAGING_API_KEY=REPLACE_ME
FIREBASE_ANDROID_STAGING_APP_ID=REPLACE_ME
FIREBASE_ANDROID_STAGING_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_ANDROID_STAGING_PROJECT_ID=REPLACE_ME
FIREBASE_ANDROID_STAGING_STORAGE_BUCKET=REPLACE_ME

FIREBASE_ANDROID_PRO_API_KEY=REPLACE_ME
FIREBASE_ANDROID_PRO_APP_ID=REPLACE_ME
FIREBASE_ANDROID_PRO_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_ANDROID_PRO_PROJECT_ID=REPLACE_ME
FIREBASE_ANDROID_PRO_STORAGE_BUCKET=REPLACE_ME

FIREBASE_IOS_DEV_API_KEY=REPLACE_ME
FIREBASE_IOS_DEV_APP_ID=REPLACE_ME
FIREBASE_IOS_DEV_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_IOS_DEV_PROJECT_ID=REPLACE_ME
FIREBASE_IOS_DEV_STORAGE_BUCKET=REPLACE_ME
FIREBASE_IOS_DEV_BUNDLE_ID=com.example.inkscroller

FIREBASE_IOS_STAGING_API_KEY=REPLACE_ME
FIREBASE_IOS_STAGING_APP_ID=REPLACE_ME
FIREBASE_IOS_STAGING_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_IOS_STAGING_PROJECT_ID=REPLACE_ME
FIREBASE_IOS_STAGING_STORAGE_BUCKET=REPLACE_ME
FIREBASE_IOS_STAGING_BUNDLE_ID=com.example.inkscroller

FIREBASE_IOS_PRO_API_KEY=REPLACE_ME
FIREBASE_IOS_PRO_APP_ID=REPLACE_ME
FIREBASE_IOS_PRO_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_IOS_PRO_PROJECT_ID=REPLACE_ME
FIREBASE_IOS_PRO_STORAGE_BUCKET=REPLACE_ME
FIREBASE_IOS_PRO_BUNDLE_ID=com.example.inkscroller
